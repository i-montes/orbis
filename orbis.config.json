{
  "$schema": "./orbis.config.schema.json",
  "version": "0.1.0",
  "name": "orbis",
  "data": {
    "path": "./data"
  },
  "memor": {
    "enabled": true,
    "database": "memor.db",
    "recency_lambda": 0.1,
    "autoEdgeThreshold": 0.85,
    "embedding": {
      "default": "ollama-qwen",
      "providers": {
        "ollama-qwen": {
          "type": "ollama",
          "model": "qwen3-embedding:0.6b",
          "dimensions": 1024,
          "baseUrl": "http://localhost:11434"
        },
        "openai-small": {
          "type": "openai",
          "model": "text-embedding-3-small",
          "dimensions": 1536
        }
      }
    },
    "hnsw": {
      "m": 16,
      "ef_construction": 200
    }
  },
  "socket": {
    "enabled": true,
    "port": 3001,
    "host": "localhost"
  },
  "mcp": {
    "enabled": true,
    "transport": "stdio"
  },
  "logger": {
    "level": "info",
    "format": "pretty"
  },
  "chat": {
    "model": "qwen3:8b"
  }
}