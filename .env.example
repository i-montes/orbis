# Configuración de Orbis
# Ruta al archivo de configuración orbis.config.json (opcional, por defecto busca en la raíz)
ORBIS_CONFIG_PATH=./orbis.config.json

# API Keys para proveedores de Embeddings y Modelos
# Obligatoria si usas OpenAI como proveedor
OPENAI_API_KEY=your_openai_api_key_here

# Otras configuraciones de entorno (ej. puertos, debug)
# PORT=3000
# LOG_LEVEL=debug
